# ── AI Provider (choose one or configure multiple for fallback) ───────────
# Primary provider: gemini | openai | anthropic | ollama | custom
AI_PROVIDER=gemini

# Gemini (Google) — variable MUST be named GEMINI_API_KEY (not API_KEY)
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI (GPT-4o, etc.)
# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_MODEL=gpt-4o

# Anthropic (Claude)
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
# ANTHROPIC_MODEL=claude-sonnet-4-6

# Ollama (local, no key needed)
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2

# OpenAI-compatible endpoint (Mistral, Groq, Together AI, etc.)
# CUSTOM_AI_BASE_URL=https://api.mistral.ai/v1
# CUSTOM_AI_API_KEY=your_key_here
# CUSTOM_AI_MODEL=mistral-large-latest

# Fallback chain (comma-separated provider names, tried in order if primary fails)
# AI_FALLBACK=openai,anthropic,ollama

# ── Scanner behaviour ─────────────────────────────────────────────────────
ENABLE_AI_ANALYSIS=true
SCAN_TIMEOUT=10
MAX_PAGES_TO_CRAWL=20

# ── Security ──────────────────────────────────────────────────────────────
# API key for the FastAPI backend — REQUIRED in production to protect the API.
# Generate a strong random value with: openssl rand -hex 32
# Leave blank only for local development (API will be completely unprotected).
API_KEY=

# Prevent the scanner from probing internal/private network ranges (SSRF guard).
# MUST be false on any public or internet-facing server.
# Set to true ONLY when intentionally scanning internal/private hosts.
ALLOW_PRIVATE_TARGETS=false

# Set to true ONLY when intentionally scanning targets with self-signed certs
ALLOW_INSECURE_TLS=false

# Expose Swagger UI (/docs, /redoc, /openapi.json) without authentication.
# Set to false (default) on production deployments to prevent API schema exposure.
EXPOSE_DOCS=false

# ── Storage ───────────────────────────────────────────────────────────────
# Path to the SQLite database file. Override for containerised deployments
# where the database should live on a mounted volume.
# DB_PATH=/data/scans.db
